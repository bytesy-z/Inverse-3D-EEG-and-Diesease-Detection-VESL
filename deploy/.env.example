# PhysDeepSIF — Docker environment variables
# Copy this file to .env and adjust values as needed.

# Backend URL that the frontend uses to reach the API
# In Docker Compose this should point to the backend service name
PHYSDEEPSIF_BACKEND_URL=http://backend:8000

# Optional: override backend ports for host binding
BACKEND_PORT=8000
FRONTEND_PORT=3000

# GPU support: set to "all" to use host GPU, or "" for CPU-only
# Requires nvidia-container-toolkit installed on the Docker host
NVIDIA_VISIBLE_DEVICES=all
