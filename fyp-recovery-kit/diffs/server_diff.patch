+                    windows_payload.append({
+                        "startTime": float(start_ts - WINDOW_LENGTH / (2 * SAMPLING_RATE)),
+                        "endTime": float(start_ts + WINDOW_LENGTH / (2 * SAMPLING_RATE)),
+                        "data": win.tolist(),
+                    })
